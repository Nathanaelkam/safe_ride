FROM python:3.12-slim

WORKDIR /app

# Copy only the auth service's requirements first for better caching
COPY services/auth/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the entire codebase (or at least services/auth and tests/ if needed)
COPY services/auth/ ./services/auth/

# The CMD uses the module path
CMD ["uvicorn", "services.auth.main:app", "--host", "0.0.0.0", "--port", "8000"]
FROM python:3.12-slim

WORKDIR /app

# Copy only the emergency service requirements first for layer caching
COPY services/emergency/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the emergency service source
COPY services/emergency/ ./services/emergency/

# Run the Emergency Trigger Service
CMD ["uvicorn", "services.emergency.app.emergency_main:app", "--host", "0.0.0.0", "--port", "8000"]

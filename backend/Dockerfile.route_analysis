FROM python:3.12-slim

WORKDIR /app
ENV PYTHONUNBUFFERED=1

COPY services/route_analysis/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY services/route_analysis/ ./services/route_analysis/

CMD ["uvicorn", "services.route_analysis.main:app", "--host", "0.0.0.0", "--port", "8000"]